# Normalize line endings to LF in the repo; convert to native on checkout.
* text=auto eol=lf

# Unity YAML files — keep as text, merge with unityyamlmerge if available
*.meta        text eol=lf merge=unityyamlmerge
*.unity       text eol=lf merge=unityyamlmerge
*.prefab      text eol=lf merge=unityyamlmerge
*.asset       text eol=lf merge=unityyamlmerge
*.anim        text eol=lf merge=unityyamlmerge
*.controller  text eol=lf merge=unityyamlmerge
*.overrideController text eol=lf merge=unityyamlmerge
*.scenetemplate text eol=lf
*.inputactions  text eol=lf

# Scripts
*.cs          text eol=lf
*.shader      text eol=lf
*.hlsl        text eol=lf
*.cginc       text eol=lf
*.json        text eol=lf
*.xml         text eol=lf
*.txt         text eol=lf
*.md          text eol=lf

# Binary — never diff or merge
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.bmp         binary
*.tga         binary
*.tiff        binary
*.psd         binary
*.pdf         binary
*.mp3         binary
*.ogg         binary
*.wav         binary
*.fbx         binary
*.obj         binary
*.dll         binary
*.exe         binary
*.unitypackage binary
*.apk         binary
*.aab         binary
